{
    "layer": "top",
    "position": "top",
    "height": 28,
    "spacing": 0,
    "margin-top": 4,
    "margin-left": 8,
    "margin-right": 8,
    "exclusive": true,
    "passthrough": false,

    "modules-left": [
        "custom/arch",
        "clock",
        "custom/target",
        "custom/updates"
    ],
 
    "custom/target": {
        "format": "󰓾 {}",
        "exec": "cat ~/.config/waybar/target.txt 2>/dev/null || echo 'no target'",
        "interval": 2,
        "tooltip": false
    },
    "modules-center": [
        "hyprland/workspaces",
        "wlr/taskbar"
    ],

    "modules-right": [
        "custom/vpn",
        "bluetooth",
        "network",
        "pulseaudio",
        "battery",
        "tray"
    ],

    "custom/arch": {
        "format": "󰣇 ",
        "on-click": "~/.config/waybar/scripts/menu.sh",
        "tooltip": false
    },
    "custom/vpn": {
        "format": "󰇧 {}",
        "exec": "ip addr show tun0 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d/ -f1 || echo 'no vpn'",
        "interval": 5,
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "●",
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "active-only": false,
        "show-special": false
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip": true,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-right": "close",
        "sort-by-app-id": true
    },

    "clock": {
        "timezone": "America/Bogota",
        "format": "  {:%I:%M:%S %p}",
        "interval": 1,
        "tooltip": false
    },

    "custom/updates": {
        "format": " {}",
        "exec": "checkupdates 2>/dev/null | wc -l",
        "interval": 3600,
        "tooltip": false
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰖁",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5,
        "tooltip": false
    },
    
    "network": {
        "format-wifi": "󰖩",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰖪",
        "tooltip-format-wifi": "{essid} {signalStrength}%",
        "tooltip": true,
        "on-click": "~/.config/hypr/scripts/network.sh",
    },
    "bluetooth": {
        "format": "󰂯",
        "format-connected": "󰂱",
        "format-off": "",
        "tooltip-format": "{controller_alias}",
        "on-click": "blueman-manager",
        "tooltip": true
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰚥",
        "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "tooltip": false
    },

    "tray": {
        "icon-size": 14,
        "spacing": 6
    }
}
